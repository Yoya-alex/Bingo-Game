# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=your_bot_username
ADMIN_IDS=123456789,987654321

# Database Configuration
DATABASE_URL=postgresql://username:password@host:5432/database_name
DB_NAME=bingo_bot
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Game Configuration
WELCOME_BONUS=10
CARD_PRICE=10
MIN_DEPOSIT=10
MIN_WITHDRAWAL=100
WAITING_TIME=50
NUMBER_CALL_INTERVAL=5
MIN_DEPOSIT_FOR_REWARD=20
REFERRAL_REWARD=10
MAX_REWARDED_REFERRALS_PER_DAY=20
MAX_TOTAL_REFERRAL_REWARDS_PER_USER=0
# Django Secret Key
SECRET_KEY=your_secret_key_here
DEBUG=False

# Production Web Security Configuration
# Set your real domains (comma-separated, no spaces)
REACT_APP_URL=https://bingo-game-1-5kj6.onrender.com
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost,127.0.0.1
WEB_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,http://localhost:5173,http://127.0.0.1:5173

# Optional: tune HSTS max-age (default in settings is 31536000 = 1 year)
SECURE_HSTS_SECONDS=31536000
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change_me