# Development environment (local machine)
# Usage:
# 1) Copy this file to .env.development
# 2) Set your real BOT_TOKEN
# 3) Ensure local PostgreSQL is running

DJANGO_ENV=development
DEBUG=True
AUTO_START_GAME_SERVICES=0

# Leave empty to force DB_* local PostgreSQL settings
DATABASE_URL=

# Local PostgreSQL
DB_NAME=bingo_bot_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432

# Telegram Bot
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
BOT_USERNAME=ethio_bingo_game_bot
ADMIN_IDS=5217880016,510837131

# App settings
SECRET_KEY=dev-insecure-change-me
ALLOWED_HOSTS=127.0.0.1,localhost
REACT_APP_URL=http://localhost:5173
WEB_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Game tuning for local dev
WELCOME_BONUS=10
CARD_PRICE=10
MIN_DEPOSIT=10
MIN_WITHDRAWAL=100
WAITING_TIME=25
NUMBER_CALL_INTERVAL=5
MIN_DEPOSIT_FOR_REWARD=20
REFERRAL_REWARD=10
MAX_REWARDED_REFERRALS_PER_DAY=20
MAX_TOTAL_REFERRAL_REWARDS_PER_USER=0
